# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PAYLOAD_SECRET=your-secret-here-change-in-production

# Database — local dev uses SQLite (no config needed)
# For production, set DATABASE_URI to a Neon Postgres connection string
# DATABASE_URI=postgres://user:pass@host/dbname?sslmode=require

# Cloudflare R2 (image storage) — leave blank for local dev (uses local /public/media)
# R2_BUCKET=
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=

# Email (Resend) — leave blank to skip email notifications in local dev
# RESEND_API_KEY=
# NOTIFY_EMAIL_FROM=inquiries@autoshoptakumi.example
# NOTIFY_EMAIL_TO=staff@autoshoptakumi.example
